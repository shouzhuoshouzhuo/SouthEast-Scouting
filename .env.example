# Spring Profile
SPRING_PROFILES_ACTIVE=dev

# PostgreSQL
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=southeast_sc
DB_USER=se_user
DB_PASSWORD=se_pass
DB_URL=jdbc:postgresql://${DB_HOST}:${DB_PORT}/${DB_NAME}

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# App
APP_IMPORT_MAX_ROWS=10000
APP_ALLOWED_IMPORT_TYPES=csv,xlsx
APP_CACHE_TTL_SEARCH_SECONDS=120
APP_CACHE_TTL_COMPARE_SECONDS=300
APP_LOCK_IMPORT_EXPIRE_SECONDS=600
